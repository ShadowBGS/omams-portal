# ============================================================
# OMAMS Web Portal - Git Ignore
# ============================================================

# Environment files (if you decide to use them locally)
.env
.env.local
.env.production
*.local

# Production config overrides (if containing sensitive data)
config.production.js

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Backup files
*.backup
*.bak
*.tmp

# Build outputs (if you add build process later)
dist/
build/
*.min.js
*.min.css

# Node modules (if you add npm later)
node_modules/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# Testing
coverage/
.nyc_output/
*.test.local.js

# Secrets (extra protection)
*secret*
*private*
serviceAccountKey.json
firebase-adminsdk*.json

# Temporary files
temp/
tmp/
